{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(rm *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(rm *)",
            "command": "bash .claude/hooks/check-rm.sh",
            "timeout": 5,
            "statusMessage": "检查 rm 命令安全性..."
          }
        ]
      }
    ]
  }
}
